message="$(cat $1)"
requiredPattern="^(add|cut|fix|bump|make|start|stop|refactor|reformat|optimise|document|merge|wip|feat): .*"

if ! [[ $message =~ $requiredPattern ]];
then
  echo "-"
  echo "🚨 Wrong commit message! 😕"
  echo "The commit message must have this format:"
  echo "<verb in imperative mood>: <what was done>"
  echo "Allowed verbs: add, cut, fix, bump, make, start, stop, refactor, reformat, optimise, document, merge, wip, feat"
  echo "-"
  echo "Your commit message was:"
  echo "$message"
  echo "-"
  exit 1
else
  echo "Commit message ok ✅"
fi
